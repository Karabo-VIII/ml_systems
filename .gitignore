# ============================================================================
# Defense-in-depth: catch-all binary patterns (NEVER commit large binaries)
# These are belt-and-suspenders on top of the path-specific rules above.
# Added 2026-04-30 after discovering 119GB of historical chimera parquets.
# ============================================================================
*.parquet
*.pt
*.pth
*.pkl
*.pickle
*.bin
*.npy
*.npz
*.h5
*.hdf5
*.feather
*.arrow

# Allow specific small reference files when explicitly tracked via -f
# (use `git add -f path/to/keepfile.parquet` if a small reference parquet
# really needs to be in the repo).
external/Kronos/

# Large TA-SML training outputs (regenerable from src/strategy/ta_sml/pipeline.py)
runs/ta_sml/15m_u50/
runs/ta_sml/1h_u50/
runs/ta_sml/4h_u10/
runs/ta_sml/4h_u50/
runs/ta_sml/4h_u50_resilient/
runs/ta_sml/live_sim/

# Large oracle-v2 training input (3.6MB; regenerable from chimera + clustering)
runs/oracle_v2/winner_events.parquet
runs/oracle_v2/emergent_clusters.parquet
runs/oracle_v2/strat_fires_*.parquet

# Large winning-formula intermediate (regenerable from step2)
runs/winning_formula/lane_weighted_fires.parquet
runs/winning_formula/daily_pnl_by_k.parquet

